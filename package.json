{
  "name": "cellhub-pro",
  "version": "2.1.2",
  "description": "CellHub Pro — Professional POS System for Cell Phone Repair Shops",
  "author": "CellHub Pro",
  "license": "UNLICENSED",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:web": "vite build --mode web",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder --config electron-builder.config.js",
    "electron:build:win": "vite build && electron-builder --win --config electron-builder.config.js",
    "electron:build:mac": "vite build && electron-builder --mac --config electron-builder.config.js",
    "electron:build:linux": "vite build && electron-builder --linux --config electron-builder.config.js",
    "electron:publish": "vite build && electron-builder --publish always --config electron-builder.config.js",
    "license:generate": "node scripts/generate-license.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "electron-updater": "^6.2.1",
    "firebase": "^10.12.0",
    "jsbarcode": "^3.11.6",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io-client": "^4.7.5",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.5.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "firebase-admin": "^13.8.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.2",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^2.1.9",
    "wait-on": "^7.2.0"
  }
}
