# Firebase Configuration
# Each CellHub Pro customer uses their own Firebase project.
# Copy this file to .env and fill in your values.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# SMS Provider (optional)
VITE_SMS_PROXY_URL=

# Companion bridge auth secret — KEEP THIS PRIVATE
# Must match BRIDGE_AUTH_SECRET set on the Railway bridge deployment.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If absent, desktop falls back to a non-production dev token.
VITE_BRIDGE_AUTH_SECRET=

# License key signing secret — KEEP THIS PRIVATE
# Change this to a long random string before distributing.
# All license keys you generate must use the same secret.
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CELLHUB_LICENSE_SECRET=
